{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://epd2.example/contracts/events/credential-issued-or-revoked-payload.v1.schema.json",
  "title": "credential.issued / credential.revoked event payload (v1)",
  "description": "docs/canonical/TZ-00-domain-event-canon.md, section 20.4. Produced by epd2_credential_service.events.credential_state_payload (shared by both build_credential_issued_event and build_credential_revoked_event). additionalProperties: false is a load-bearing identity-leakage control (CT-00-08): no identity_record_id, person_id, account_id, or any other identity field can appear on a payload that validates against this schema.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "credential_id",
    "credential_type",
    "scope_type",
    "scope_id",
    "status",
    "credential_version",
    "rule_version",
    "eligibility_snapshot_digest",
    "expires_at"
  ],
  "properties": {
    "credential_id": { "type": "string", "format": "uuid" },
    "credential_type": {
      "type": "string",
      "enum": [
        "space_access",
        "initiative_support",
        "ballot_access",
        "delegation_access",
        "audit_access"
      ]
    },
    "scope_type": { "type": "string", "minLength": 1 },
    "scope_id": { "type": "string", "format": "uuid" },
    "status": {
      "type": "string",
      "enum": ["issued", "active", "used", "expired", "revoked", "invalid"]
    },
    "credential_version": { "type": "integer" },
    "rule_version": { "type": "integer" },
    "eligibility_snapshot_digest": { "type": "string", "minLength": 1 },
    "expires_at": { "type": "string", "format": "date-time" }
  }
}
