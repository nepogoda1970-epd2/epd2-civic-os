{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://epd2.example/contracts/events/transparency-ledger-entry-payload.v1.schema.json",
  "title": "TransparencyLedgerEntryPayloadV1",
  "description": "Payload shape for transparency.ledger_entry_published and transparency.ledger_entry_corrected (canon section 20.14; epd2_transparency_service.events.ledger_entry_public_payload). Deliberately omits published_by_role_id (canon section 19a.6: never published verbatim).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "public_ledger_entry_id",
    "subject_type",
    "subject_id",
    "subject_event_id",
    "published_at",
    "content_snapshot",
    "content_hash",
    "previous_entry_hash",
    "disclosure_policy_id",
    "redaction_notice",
    "supersedes_entry_id",
    "status"
  ],
  "properties": {
    "public_ledger_entry_id": { "type": "string", "format": "uuid" },
    "subject_type": {
      "type": "string",
      "enum": [
        "initiative",
        "initiative_version",
        "moderation_decision",
        "result_publication",
        "ai_processing_record"
      ]
    },
    "subject_id": { "type": "string", "format": "uuid" },
    "subject_event_id": { "type": "string", "format": "uuid" },
    "published_at": { "type": "string", "format": "date-time" },
    "content_snapshot": { "type": "object" },
    "content_hash": { "type": "string", "minLength": 1 },
    "previous_entry_hash": { "type": "string", "minLength": 1 },
    "disclosure_policy_id": { "type": "string", "format": "uuid" },
    "redaction_notice": { "type": ["string", "null"] },
    "supersedes_entry_id": { "type": ["string", "null"], "format": "uuid" },
    "status": { "type": "string", "enum": ["published"] }
  }
}
