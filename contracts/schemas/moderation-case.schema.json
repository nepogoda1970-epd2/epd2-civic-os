{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://epd2.example/contracts/schemas/moderation-case.schema.json",
  "title": "ModerationCase",
  "description": "docs/canonical/TZ-00-domain-event-canon.md, section 14.1. Owned by moderation-service (epd2_moderation_service.domain.ModerationCase, ADR-005 consolidation of 'Moderation Service' and 'Appeal Service'). `assigned_moderator` is nullable until `assign_moderator` (open -> under_review) sets it.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "moderation_case_id",
    "target_type",
    "target_id",
    "opened_by",
    "trigger_type",
    "policy_version",
    "status",
    "assigned_moderator"
  ],
  "properties": {
    "moderation_case_id": { "type": "string", "format": "uuid" },
    "target_type": { "type": "string", "minLength": 1 },
    "target_id": { "type": "string", "format": "uuid" },
    "opened_by": { "type": "string", "format": "uuid" },
    "trigger_type": { "type": "string", "minLength": 1 },
    "policy_version": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "under_review",
        "action_proposed",
        "decided",
        "appealed",
        "closed"
      ]
    },
    "assigned_moderator": { "type": ["string", "null"], "format": "uuid" }
  }
}
