{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://epd2.example/contracts/schemas/public-ledger-entry.schema.json",
  "title": "PublicLedgerEntry",
  "description": "docs/canonical/TZ-00-domain-event-canon.md, section 19a.1 (added by canon 0.3.0, ADR-013). Owned by transparency-service (epd2_transparency_service.domain.PublicLedgerEntry). Only status value is 'published' - never rewritten after creation; a correction is a new row with supersedes_entry_id set. published_by_role_id is a real, stored, internal RoleAssignment reference but is never present in any public payload built from events.ledger_entry_public_payload - this schema still lists it because it describes the stored domain entity, not the public wire payload.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "public_ledger_entry_id",
    "subject_type",
    "subject_id",
    "subject_event_id",
    "published_at",
    "published_by_role_id",
    "content_snapshot",
    "content_hash",
    "previous_entry_hash",
    "disclosure_policy_id",
    "redaction_notice",
    "supersedes_entry_id",
    "status"
  ],
  "properties": {
    "public_ledger_entry_id": { "type": "string", "format": "uuid" },
    "subject_type": {
      "type": "string",
      "enum": [
        "initiative",
        "initiative_version",
        "moderation_decision",
        "result_publication",
        "ai_processing_record"
      ]
    },
    "subject_id": { "type": "string", "format": "uuid" },
    "subject_event_id": { "type": "string", "format": "uuid" },
    "published_at": { "type": "string", "format": "date-time" },
    "published_by_role_id": { "type": "string", "format": "uuid" },
    "content_snapshot": { "type": "object" },
    "content_hash": { "type": "string", "minLength": 1 },
    "previous_entry_hash": { "type": "string", "minLength": 1 },
    "disclosure_policy_id": { "type": "string", "format": "uuid" },
    "redaction_notice": { "type": ["string", "null"] },
    "supersedes_entry_id": { "type": ["string", "null"], "format": "uuid" },
    "status": { "type": "string", "enum": ["published"] }
  }
}
