{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://epd2.example/contracts/schemas/eligibility-rule.schema.json",
  "title": "EligibilityRule",
  "description": "docs/canonical/TZ-00-domain-event-canon.md, section 9.1. Owned by eligibility-service (epd2_eligibility_service.domain.EligibilityRule). Immutable per (eligibility_rule_id, rule_version) - canon section 9.1 / CT-00-10 rule freeze.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eligibility_rule_id",
    "rule_version",
    "scope_type",
    "scope_id",
    "required_membership_status",
    "required_verification_level",
    "region_constraint",
    "minimum_membership_age",
    "exclusion_conditions",
    "valid_from",
    "valid_until"
  ],
  "properties": {
    "eligibility_rule_id": { "type": "string", "format": "uuid" },
    "rule_version": { "type": "integer" },
    "scope_type": { "type": "string", "minLength": 1 },
    "scope_id": { "type": "string", "format": "uuid" },
    "required_membership_status": { "type": "string", "minLength": 1 },
    "required_verification_level": { "type": "string", "minLength": 1 },
    "region_constraint": { "type": ["string", "null"] },
    "minimum_membership_age": { "type": ["integer", "null"] },
    "exclusion_conditions": { "type": "array", "items": { "type": "string" } },
    "valid_from": { "type": "string", "format": "date-time" },
    "valid_until": { "type": ["string", "null"], "format": "date-time" }
  }
}
