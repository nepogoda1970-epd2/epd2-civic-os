{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://epd2.example/contracts/schemas/participation-credential.schema.json",
  "title": "ParticipationCredential",
  "description": "docs/canonical/TZ-00-domain-event-canon.md, section 10.1 (union with pack section 6.1 fields, ADR-002). Owned by credential-service (epd2_credential_service.domain.ParticipationCredential). additionalProperties: false is a load-bearing identity-leakage control (CT-00-08, pack section 5.2 / 12.2): identity_record_id, person_id, account_id, full_name, date_of_birth, address, email, and eid_subject are all forbidden and cannot appear on an instance that validates against this schema.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "credential_id",
    "credential_type",
    "scope_type",
    "scope_id",
    "issued_at",
    "valid_from",
    "expires_at",
    "status",
    "usage_limit",
    "usage_counter",
    "revocation_status",
    "issuer_signature",
    "credential_version",
    "rule_version",
    "eligibility_snapshot_digest"
  ],
  "properties": {
    "credential_id": { "type": "string", "format": "uuid" },
    "credential_type": {
      "type": "string",
      "enum": [
        "space_access",
        "initiative_support",
        "ballot_access",
        "delegation_access",
        "audit_access"
      ]
    },
    "scope_type": { "type": "string", "minLength": 1 },
    "scope_id": { "type": "string", "format": "uuid" },
    "issued_at": { "type": "string", "format": "date-time" },
    "valid_from": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["issued", "active", "used", "expired", "revoked", "invalid"]
    },
    "usage_limit": { "type": ["integer", "null"] },
    "usage_counter": { "type": "integer" },
    "revocation_status": { "type": "string", "minLength": 1 },
    "issuer_signature": { "type": ["string", "null"] },
    "credential_version": { "type": "integer" },
    "rule_version": { "type": "integer" },
    "eligibility_snapshot_digest": { "type": "string", "minLength": 1 }
  }
}
