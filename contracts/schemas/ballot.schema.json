{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://epd2.example/contracts/schemas/ballot.schema.json",
  "title": "Ballot",
  "description": "docs/canonical/TZ-00-domain-event-canon.md, section 15.1 (ADR-005 consolidates 'Ballot Definition Service'/'Vote Casting Service'/'Receipt Service' into voting-service). Owned by voting-service (epd2_voting_service.domain.Ballot). No extra public field beyond canon's own list - internal bookkeeping (created_by_actor_id for ADR-009 item 7's second-actor approval check; the frozen EligibilitySnapshot digest) lives only in storage.py, never here. `configuration_hash`/`challenge_window_hours` are nullable until CT-00-10's freeze (draft -> configuration_review) sets/resolves them.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ballot_id",
    "space_id",
    "subject_type",
    "subject_id",
    "question",
    "ballot_method",
    "secrecy_mode",
    "eligibility_rule_version",
    "delegation_policy_version",
    "quorum_rule",
    "threshold_rule",
    "opens_at",
    "closes_at",
    "status",
    "configuration_hash",
    "challenge_window_hours"
  ],
  "properties": {
    "ballot_id": { "type": "string", "format": "uuid" },
    "space_id": { "type": "string", "format": "uuid" },
    "subject_type": { "type": "string", "minLength": 1 },
    "subject_id": { "type": "string", "format": "uuid" },
    "question": { "type": "string", "minLength": 1 },
    "ballot_method": {
      "type": "string",
      "enum": ["single_choice", "yes_no"]
    },
    "secrecy_mode": { "type": "string", "minLength": 1 },
    "eligibility_rule_version": { "type": "integer", "minimum": 1 },
    "delegation_policy_version": { "type": "integer", "minimum": 1 },
    "quorum_rule": { "type": "string" },
    "threshold_rule": { "type": "string" },
    "opens_at": { "type": "string", "format": "date-time" },
    "closes_at": { "type": "string", "format": "date-time" },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "configuration_review",
        "scheduled",
        "open",
        "paused",
        "closed",
        "tallying",
        "tallied",
        "published",
        "cancelled",
        "invalidated"
      ]
    },
    "configuration_hash": { "type": ["string", "null"] },
    "challenge_window_hours": { "type": ["integer", "null"], "minimum": 0 }
  }
}
